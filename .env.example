# =============================================================================
# EmpireForge — Пример переменных окружения
# =============================================================================
# Скопируйте в .env и заполните свои значения:
#   cp .env.example .env
# =============================================================================

# Telegram Bot (обязательные)
TELEGRAM_BOT_USERNAME=empireforge_bot
TELEGRAM_BOT_TOKEN=получить_у_BotFather

# Telegram Webhook (для продакшена)
TELEGRAM_BOT_WEBHOOK_PATH=https://your-domain.com/telegram
TELEGRAM_BOT_SECRET_TOKEN=случайная_строка_32_символа

# Режим получения обновлений (true = long polling, false = webhook)
TELEGRAM_BOT_LONG_POLLING=true

# H2 Console (включить только в dev)
SPRING_H2_CONSOLE_ENABLED=true
